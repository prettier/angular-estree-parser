{
  "name": "angular-estree-parser",
  "version": "15.4.3",
  "description": "A parser that converts Angular source code into an ESTree-compatible form",
  "keywords": [],
  "repository": "https://github.com/prettier/angular-estree-parser",
  "homepage": "https://github.com/prettier/angular-estree-parser#readme",
  "author": {
    "name": "Ika",
    "email": "ikatyang@gmail.com",
    "url": "https://github.com/ikatyang"
  },
  "exports": "./dist/index.js",
  "license": "MIT",
  "scripts": {
    "prepare": "yarn run build",
    "test": "vitest",
    "test-coverage": "vitest --coverage",
    "lint": "run-p \"lint:*\"",
    "lint:eslint": "eslint",
    "lint:prettier": "prettier --check .",
    "lint:types": "tsc --noEmit",
    "fix": "run-s \"fix:*\"",
    "fix:eslint": "yarn lint:eslint --fix",
    "fix:prettier": "yarn lint:prettier --write",
    "build": "tsdown --unbundle",
    "release": "release-it"
  },
  "devDependencies": {
    "@angular/compiler": "21.2.8",
    "@babel/code-frame": "8.0.0-rc.3",
    "@babel/parser": "8.0.0-rc.3",
    "@babel/types": "8.0.0-rc.3",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.4",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.4.0",
    "jest-snapshot-serializer-raw": "2.0.0",
    "lines-and-columns": "2.0.4",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.2",
    "release-it": "20.0.1",
    "tsdown": "0.21.7",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.1",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "@angular/compiler": ">=21.0.7 || >= 21.2.0-0"
  },
  "engines": {
    "node": ">= 20"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "yarn@4.13.0"
}
